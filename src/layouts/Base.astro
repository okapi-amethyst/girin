---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "2XKO GIRIN — これだけ覚えたら対戦行ってOK" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        if (saved) {
          document.documentElement.setAttribute('data-theme', saved);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href={base} class="site-logo">
          <span class="logo-text">GIRIN</span>
        </a>
        <span class="site-badge">2XKO</span>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="テーマ切替">
          <span class="theme-icon-dark">☀</span>
          <span class="theme-icon-light">☾</span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>2XKO GIRIN — これだけ覚えたら対戦行ってOK</p>
      </div>
    </footer>
  </body>
</html>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>

<style>
  @import "../styles/global.css";

  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }

  .site-header .container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .site-logo:hover {
    color: var(--color-text);
  }

  .site-badge {
    background: var(--color-accent);
    color: #0a0a0f;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .theme-toggle {
    margin-left: auto;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.3rem 0.5rem;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .theme-toggle:hover {
    border-color: var(--color-accent);
  }

  /* dark theme: show sun icon (switch to light) */
  :root:not([data-theme="light"]) .theme-icon-light { display: none; }
  :root:not([data-theme="light"]) .theme-icon-dark { display: inline; }

  /* light theme: show moon icon (switch to dark) */
  :root[data-theme="light"] .theme-icon-dark { display: none; }
  :root[data-theme="light"] .theme-icon-light { display: inline; }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 3rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
</style>
