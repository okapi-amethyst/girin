---
import PairComboPage from '../../../components/PairComboPage.astro';
import { characters } from '../../../data/characters';
import type { Character } from '../../../data/characters';
import { sampleCombos } from '../../../data/sample-combos';
import { FUSE_SLUGS, resolveFuseFilter } from '../../../data/pair-page';

export function getStaticPaths() {
  const paths = [];

  for (let i = 0; i < characters.length; i++) {
    for (let j = i + 1; j < characters.length; j++) {
      const charA = characters[i];
      const charB = characters[j];

      paths.push({
        params: { char1: charA.slug, char2: charB.slug, fuse: undefined },
        props: { charA, charB, fuseSlug: null, fuseLabel: null },
      });

      for (const fuse of FUSE_SLUGS) {
        paths.push({
          params: { char1: charA.slug, char2: charB.slug, fuse: fuse.slug },
          props: { charA, charB, fuseSlug: fuse.slug, fuseLabel: fuse.label },
        });
      }
    }
  }

  return paths;
}

interface Props {
  charA: Character;
  charB: Character;
  fuseSlug: string | null;
  fuseLabel: string | null;
}

const { charA, charB, fuseSlug, fuseLabel } = Astro.props;
const isAhriYasuo = charA.slug === 'ahri' && charB.slug === 'yasuo';
const fuseFilter = resolveFuseFilter(fuseSlug);
const combos = isAhriYasuo
  ? (fuseFilter ? sampleCombos.filter((combo) => combo.fuse === fuseFilter) : sampleCombos)
  : [];
---

<PairComboPage charA={charA} charB={charB} combos={combos} fuseSlug={fuseSlug} fuseLabel={fuseLabel} />
