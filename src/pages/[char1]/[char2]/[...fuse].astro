---
import Base from "../../../layouts/Base.astro";
import ComboCard from "../../../components/ComboCard.astro";
import { characters } from "../../../data/characters";
import type { Character } from "../../../data/characters";
import { sampleCombos } from "../../../data/sample-combos";

// Juggernaut はソロFuseなのでペアページからは除外
const FUSE_SLUGS = [
  { slug: "double-down", label: "DOUBLE DOWN" },
  { slug: "2x-assist", label: "2X ASSIST" },
  { slug: "freestyle", label: "FREESTYLE" },
  { slug: "sidekick", label: "SIDEKICK" },
  { slug: "sidekick-alt", label: "SIDEKICK" },
];

export function getStaticPaths() {
  const fuseList = [
    { slug: "double-down", label: "DOUBLE DOWN" },
    { slug: "2x-assist", label: "2X ASSIST" },
    { slug: "freestyle", label: "FREESTYLE" },
    { slug: "sidekick", label: "SIDEKICK" },
    { slug: "sidekick-alt", label: "SIDEKICK" },
  ];

  const paths: Array<{
    params: { char1: string; char2: string; fuse?: string };
    props: { charA: Character; charB: Character; fuseSlug: string | null; fuseLabel: string | null };
  }> = [];

  for (let i = 0; i < characters.length; i++) {
    for (let j = i + 1; j < characters.length; j++) {
      const a = characters[i];
      const b = characters[j];

      // ペアトップ（No Fuse）
      paths.push({
        params: { char1: a.slug, char2: b.slug, fuse: undefined },
        props: { charA: a, charB: b, fuseSlug: null, fuseLabel: null },
      });

      // Fuse別ページ
      for (const f of fuseList) {
        paths.push({
          params: { char1: a.slug, char2: b.slug, fuse: f.slug },
          props: { charA: a, charB: b, fuseSlug: f.slug, fuseLabel: f.label },
        });
      }
    }
  }

  return paths;
}

interface Props {
  charA: Character;
  charB: Character;
  fuseSlug: string | null;
  fuseLabel: string | null;
}

const { charA, charB, fuseSlug, fuseLabel } = Astro.props;
const base = import.meta.env.BASE_URL;
const pairBase = `${base}${charA.slug}/${charB.slug}/`;

// ページタイトル
const pageTitle = fuseLabel
  ? `${charA.nameJa} × ${charB.nameJa} ${fuseLabel} — 2XKO GIRIN`
  : `${charA.nameJa} × ${charB.nameJa} — 2XKO GIRIN`;

// 現在のFuseハイライト用
const currentFuse = fuseSlug || "none";

// サンプルコンボ表示（ahri×yasuoのみ）
const isAhriYasuo = charA.slug === "ahri" && charB.slug === "yasuo";
const fuseFilter = fuseSlug
  ? fuseSlug === "double-down" ? "Double Down"
    : fuseSlug === "2x-assist" ? "2X Assist"
    : fuseSlug === "freestyle" ? "Freestyle"
    : fuseSlug === "sidekick" ? "Sidekick"
    : fuseSlug === "sidekick-alt" ? "Sidekick"
    : null
  : null; // null = ALL (No Fuse含む全表示)
const filteredCombos = isAhriYasuo
  ? fuseFilter
    ? sampleCombos.filter(c => c.fuse === fuseFilter)
    : sampleCombos
  : [];

// Sidekickポイントラベル
function sidekickPointLabel(slug: string): string {
  if (slug === "sidekick") return `${charA.nameJa} ポイント`;
  if (slug === "sidekick-alt") return `${charB.nameJa} ポイント`;
  return "";
}

// Wiki crop
function scaleCrop(crop: { bgSize: string; bgPosition: string }) {
  const size = parseInt(crop.bgSize);
  const parts = crop.bgPosition.match(/-?\d+/g)?.map(Number) || [0, 0];
  return { size, posX: parts[0], posY: parts[1] };
}
---

<Base title={pageTitle}>
  <div class="container page">
    <nav class="breadcrumb">
      <a href={base}>トップ</a>
    </nav>

    <!-- ペアヘッダー -->
    <header class="pair-header">
      <div class="pair-icons">
        {charA.crop ? (
          <div
            class="pair-icon"
            data-size={scaleCrop(charA.crop).size}
            data-pos-x={scaleCrop(charA.crop).posX}
            data-pos-y={scaleCrop(charA.crop).posY}
            style={`background-image: url(${base}images/champions/600px-${charA.slug}.png);`}
          />
        ) : (
          <div class="pair-icon pair-icon-fallback"><span>{charA.nameJa[0]}</span></div>
        )}
        <span class="pair-x">×</span>
        {charB.crop ? (
          <div
            class="pair-icon"
            data-size={scaleCrop(charB.crop).size}
            data-pos-x={scaleCrop(charB.crop).posX}
            data-pos-y={scaleCrop(charB.crop).posY}
            style={`background-image: url(${base}images/champions/600px-${charB.slug}.png);`}
          />
        ) : (
          <div class="pair-icon pair-icon-fallback"><span>{charB.nameJa[0]}</span></div>
        )}
      </div>
      <div class="pair-names">
        <h1>{charA.nameJa} × {charB.nameJa}</h1>
        {fuseLabel && (
          <p class="fuse-current-label">
            {fuseLabel}
            {(fuseSlug === "sidekick" || fuseSlug === "sidekick-alt") && (
              <span class="sidekick-dir">({sidekickPointLabel(fuseSlug)})</span>
            )}
          </p>
        )}
      </div>
    </header>

    <!-- ペア探しリンク -->
    <div class="pair-nav-links">
      <a href={`${base}${charA.slug}/`} class="pair-nav-link">{charA.nameJa} のペアを探す</a>
      <a href={`${base}${charB.slug}/`} class="pair-nav-link">{charB.nameJa} のペアを探す</a>
    </div>

    <!-- Fuse選択UI -->
    <nav class="fuse-nav">
      <a
        href={pairBase}
        class:list={["fuse-chip", { active: currentFuse === "none" }]}
      >ALL</a>
      {FUSE_SLUGS.map((f) => (
        <a
          href={`${pairBase}${f.slug}/`}
          class:list={["fuse-chip", { active: currentFuse === f.slug }]}
        >
          {f.label}
          {(f.slug === "sidekick" || f.slug === "sidekick-alt") && (
            <span class="fuse-chip-sub">{sidekickPointLabel(f.slug)}</span>
          )}
        </a>
      ))}
    </nav>

    <!-- Headroomナビバー（スクロールで上からスライドイン） -->
    <div class="headroom-nav" id="headroom-nav">
      <a href={pairBase} class="headroom-nav-link">
        {charA.nameJa} × {charB.nameJa}
        {fuseLabel && <span class="headroom-nav-fuse">{fuseLabel}</span>}
      </a>
    </div>

    <!-- フィルター: Collapsible Filter Bar（コンボカード上） -->
    <div class="filter-bar" id="filter-bar">
      <div class="filter-row">
        <div class="filter-group">
          <span class="filter-label">難易度</span>
          <div class="filter-chips" data-filter="difficulty">
            <button class="chip chip-pulse" data-value="1">★ <span class="pulse-badge">Pulse</span></button>
            <button class="chip chip-pulse" data-value="2">★★ <span class="pulse-badge">Pulse</span></button>
            <button class="chip" data-value="3">★★★</button>
            <button class="chip" data-value="4">★★★★</button>
            <button class="chip" data-value="5">★★★★★</button>
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">始動</span>
          <div class="filter-chips" data-filter="starter">
            <button class="chip" data-value="ground">地上</button>
            <button class="chip" data-value="anti-air">対空</button>
            <button class="chip" data-value="counter">CH</button>
            <button class="chip" data-value="throw">投げ</button>
            <button class="chip" data-value="other">他</button>
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">位置</span>
          <div class="filter-chips" data-filter="position">
            <button class="chip" data-value="center">中央</button>
            <button class="chip" data-value="corner">端</button>
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">並び順</span>
          <select class="sort-select" id="sort-select">
            <option value="practicality-desc">実用度</option>
            <option value="difficulty-asc">難易度（低い順）</option>
            <option value="damage-desc">ダメージ（高い順）</option>
          </select>
        </div>
        <button class="expand-toggle" id="filter-expand" type="button">
          その他
          <span class="expand-icon" id="expand-icon">▼</span>
        </button>
      </div>
      <div class="filter-panel" id="filter-panel" style="display: none;">
        <div class="filter-row">
          <div class="filter-group">
            <label class="toggle-label">
              <input type="checkbox" data-filter="assist_used" />
              アシスト使用
            </label>
          </div>
          <div class="filter-group">
            <label class="toggle-label">
              <input type="checkbox" data-filter="tag" />
              交代（タグ）
            </label>
          </div>
          <div class="filter-group">
            <label class="toggle-label">
              <input type="checkbox" data-filter="duo_only" />
              デュオ限定
            </label>
          </div>
        </div>
        <div class="filter-row">
          <div class="filter-group">
            <span class="filter-label">Pゲージ</span>
            <select data-filter="ult_gauge_point">
              <option value="">全て</option>
              <option value="0">0</option>
              <option value="1">1+</option>
            </select>
          </div>
          <div class="filter-group">
            <span class="filter-label">Aゲージ</span>
            <select data-filter="ult_gauge_assist">
              <option value="">全て</option>
              <option value="0">0</option>
              <option value="1">1+</option>
            </select>
          </div>
          <div class="filter-group">
            <span class="filter-label">タグ</span>
            <div class="filter-chips" data-filter="tags">
              <button class="chip" data-value="oki">起き攻め</button>
              <button class="chip" data-value="carry">端運び</button>
              <button class="chip" data-value="swap">入替え</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- コンテンツ + 動画（PCではフレックス横並び） -->
    <div class="content-layout" id="content-layout">
      <!-- 動画パネル（モバイル=上部sticky、PC=右サイドsticky） -->
      <div class="video-panel" id="video-panel" style="display: none;">
        <div class="vp-inner">
          <div class="vp-player">
            <iframe
              id="vp-iframe"
              src=""
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="vp-info">
            <div class="vp-meta">
              <span class="vp-label" id="vp-label"></span>
              <button class="vp-close" id="vp-close" type="button" title="閉じる">×</button>
            </div>
            <div class="vp-inputs">
              <code id="vp-inputs-code"></code>
            </div>
          </div>
        </div>
      </div>

      <!-- コンボ一覧 -->
      <section class="combo-area" id="combo-area">
        {filteredCombos.length > 0 ? (
          <div class="combo-list">
            {filteredCombos.map((c) => (
              <ComboCard combo={c} pointName={charA.nameJa} assistName={charB.nameJa} />
            ))}
          </div>
        ) : (
          <div class="combo-empty">
            <p>コンボデータ準備中</p>
            <p class="combo-empty-sub">このペア × Fuseのコンボが登録されると、ここに表示されます</p>
          </div>
        )}
      </section>
    </div>

    <!-- Coming Soon リンク -->
    <section class="coming-soon-links">
      <a href={`${base}mycombo/`} class="cs-link">
        My Combos
        <span class="badge-coming-soon">Coming Soon</span>
      </a>
      <a href="#" class="cs-link">
        Submit Combo
        <span class="badge-coming-soon">Coming Soon</span>
      </a>
    </section>
  </div>
</Base>

<script>
  document.addEventListener('DOMContentLoaded', () => {
  // ポートレートスケーリング
  const WIKI_REF = 180;
  function scalePortraits() {
    document.querySelectorAll<HTMLElement>('[data-size]').forEach(el => {
      const w = el.clientWidth;
      if (w === 0) return;
      const scale = w / WIKI_REF;
      el.style.backgroundSize = `${Number(el.dataset.size) * scale}px`;
      el.style.backgroundPosition = `${Number(el.dataset.posX) * scale}px ${Number(el.dataset.posY) * scale}px`;
    });
  }
  scalePortraits();
  window.addEventListener('resize', () => {
    scalePortraits();
    if (activeComboId) updateVideoPanelTop();
  });

  // --- Headroom ナビバー（スクロール方向で判定） ---
  const headroomNav = document.getElementById('headroom-nav');
  const filterBar = document.getElementById('filter-bar');
  let headroomVisible = false;
  let lastScrollY = window.scrollY;

  function updateHeadroom() {
    if (!headroomNav || !filterBar) return;
    const filterBottom = filterBar.getBoundingClientRect().bottom;
    const currentScrollY = window.scrollY;
    const scrollingDown = currentScrollY > lastScrollY;
    lastScrollY = currentScrollY;

    // フィルタバーが画面外に出ている場合のみHeadroomを考慮
    if (filterBottom >= 0) {
      // フィルタバーが見えている → Headroom非表示
      if (headroomVisible) {
        headroomVisible = false;
        headroomNav.classList.remove('visible');
        updateVideoPanelTop();
      }
      return;
    }

    // フィルタバーが画面外 → 下スクロールで表示、上スクロールで非表示
    const shouldShow = scrollingDown;
    if (shouldShow !== headroomVisible) {
      headroomVisible = shouldShow;
      headroomNav.classList.toggle('visible', shouldShow);
      updateVideoPanelTop();
    }
  }

  window.addEventListener('scroll', updateHeadroom, { passive: true });

  // フィルタ展開パネル
  const expandBtn = document.getElementById('filter-expand');
  const panel = document.getElementById('filter-panel');
  const icon = document.getElementById('expand-icon');
  expandBtn?.addEventListener('click', () => {
    const hidden = panel?.style.display === 'none';
    if (panel) panel.style.display = hidden ? '' : 'none';
    if (icon) icon.textContent = hidden ? '▲' : '▼';
  });

  // チップ選択トグル（見た目のみ）
  document.querySelectorAll('.filter-chips').forEach(group => {
    group.querySelectorAll('.chip').forEach(chip => {
      chip.addEventListener('click', () => {
        chip.classList.toggle('active');
      });
    });
  });

  // --- 動画パネル ---
  let activeComboId: string | null = null;
  const HEADROOM_HEIGHT = 34;

  function updateVideoPanelTop() {
    const videoPanel = document.getElementById('video-panel');
    if (!videoPanel || activeComboId === null) return;
    // 全サイズ共通: Headroom連動でsticky top調整
    videoPanel.style.top = `${headroomVisible ? HEADROOM_HEIGHT : 0}px`;
  }

  function extractVideoId(url: string): string | null {
    const shortMatch = url.match(/youtu\.be\/([^?&]+)/);
    if (shortMatch) return shortMatch[1];
    const longMatch = url.match(/[?&]v=([^&]+)/);
    if (longMatch) return longMatch[1];
    return null;
  }

  function toEmbedUrl(url: string): string {
    const id = extractVideoId(url);
    if (id) return `https://www.youtube.com/embed/${id}?rel=0&mute=1&autoplay=1&loop=1&playlist=${id}`;
    return url;
  }

  function openVideoPanel(card: HTMLElement) {
    const videoPanel = document.getElementById('video-panel');
    const vpIframe = document.getElementById('vp-iframe') as HTMLIFrameElement | null;
    const vpLabel = document.getElementById('vp-label');
    const vpInputsCode = document.getElementById('vp-inputs-code');
    const btn = card.querySelector<HTMLButtonElement>('.cc-video-btn');
    if (!btn || !videoPanel || !vpIframe || !vpLabel || !vpInputsCode) return;

    const videoUrl = btn.dataset.videoUrl;
    const inputs = btn.dataset.videoInputs;
    const comboId = btn.dataset.videoComboId;
    const damage = btn.dataset.videoDamage;
    const difficulty = btn.dataset.videoDifficulty;
    if (!videoUrl || !inputs) return;

    if (activeComboId === comboId) {
      closeVideoPanel();
      return;
    }

    vpIframe.src = toEmbedUrl(videoUrl);
    vpInputsCode.textContent = inputs;
    const stars = '★'.repeat(Number(difficulty)) + '☆'.repeat(5 - Number(difficulty));
    vpLabel.textContent = `#${comboId}  ${stars}  ${Number(damage).toLocaleString()} dmg`;
    videoPanel.style.display = '';

    document.querySelectorAll('.combo-card.playing').forEach(c => c.classList.remove('playing'));
    card.classList.add('playing');
    activeComboId = comboId ?? null;

    updateVideoPanelTop();
    videoPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function closeVideoPanel() {
    const videoPanel = document.getElementById('video-panel');
    const vpIframe = document.getElementById('vp-iframe') as HTMLIFrameElement | null;
    if (!videoPanel || !vpIframe) return;
    videoPanel.style.display = 'none';
    vpIframe.src = '';
    document.querySelectorAll('.combo-card.playing').forEach(c => c.classList.remove('playing'));
    activeComboId = null;

    videoPanel.style.top = '';
  }

  // クリック挙動（イベント委譲）
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    if (target.closest('#vp-close')) {
      closeVideoPanel();
      return;
    }

    if (target.closest('#video-panel')) return;

    const videoBtn = target.closest<HTMLElement>('.cc-video-btn');
    if (videoBtn) {
      const card = videoBtn.closest<HTMLElement>('.combo-card');
      if (card) openVideoPanel(card);
      return;
    }

    const card = target.closest<HTMLElement>('.combo-card');
    if (card) {
      if (target.closest('button, a, input, select')) return;
      if (activeComboId) {
        closeVideoPanel();
      } else {
        openVideoPanel(card);
      }
      return;
    }

    if (activeComboId) {
      closeVideoPanel();
    }
  });
  }); // end DOMContentLoaded
</script>

<style>
  .page {
    padding-top: 1.5rem;
    padding-bottom: 2rem;
    max-width: 960px;
    margin: 0 auto;
  }

  /* Headroomナビバー（スクロールトリガー固定ヘッダー） */
  .headroom-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 0.4rem 0.75rem;
    display: flex;
    align-items: center;
    transform: translateY(-100%);
    transition: transform 0.25s ease;
    pointer-events: none;
  }

  .headroom-nav.visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  .headroom-nav-link {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .headroom-nav-link:hover {
    color: var(--color-accent);
  }

  .headroom-nav-fuse {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* ペアヘッダー */
  .pair-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .pair-icons {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .pair-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-repeat: no-repeat;
    background-color: var(--color-border);
  }

  .pair-icon-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .pair-x {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .pair-names h1 {
    font-size: 1.3rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .fuse-current-label {
    color: var(--color-accent);
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 0.15rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .sidekick-dir {
    color: var(--color-text-muted);
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: none;
  }

  /* ペア探しリンク */
  .pair-nav-links {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .pair-nav-link {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    border-bottom: 1px dashed var(--color-border);
    padding-bottom: 1px;
    transition: color 0.15s;
  }

  .pair-nav-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  /* Fuse選択ナビ */
  .fuse-nav {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
    overflow-x: auto;
  }

  .fuse-chip {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
    line-height: 1.3;
  }

  .fuse-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .fuse-chip.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface));
  }

  .fuse-chip-sub {
    font-size: 0.55rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0;
  }

  /* フィルタバー */
  .filter-bar {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem;
    margin-bottom: 1.25rem;
    overflow-x: auto;
  }

  .filter-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .filter-group {
