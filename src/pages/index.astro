---
import Base from "../layouts/Base.astro";
import { characters } from "../data/characters";

function scaleCrop(crop: { bgSize: string; bgPosition: string }) {
  const size = parseInt(crop.bgSize);
  const parts = crop.bgPosition.match(/-?\d+/g)?.map(Number) || [0, 0];
  return { size, posX: parts[0], posY: parts[1] };
}
---

<Base title="2XKO コンボ集 | GIRIN">
  <section class="hero">
    <div class="container">
      <p class="hero-sub">今のあなたに最適なコンボがみつかるかも</p>
    </div>
  </section>

  <section class="nav-links">
    <div class="container nav-links-row">
      <a href="#" class="nav-link-card nav-link-disabled">
        <span class="nav-link-label">新着コンボ</span>
        <span class="nav-link-desc">新しいコンボをみる</span>
      </a>
      <a href={`${import.meta.env.BASE_URL}mycombo/`} class="nav-link-card nav-link-disabled">
        <span class="nav-link-label">My Combos</span>
        <span class="nav-link-desc">保存したコンボをみる</span>
      </a>
      <a href="#" class="nav-link-card nav-link-disabled">
        <span class="nav-link-label">コンボ投稿</span>
        <span class="nav-link-desc">コンボを共有する</span>
      </a>
    </div>
  </section>

  <section class="characters">
    <div class="container">
      <h2 class="char-grid-title">コンボを調べたいチャンピオンを選択</h2>
      <div class="char-grid">
        {characters.map((char) => {
          const crop = char.crop ? scaleCrop(char.crop) : null;
          return (
            <a href={`${import.meta.env.BASE_URL}${char.slug}/`} class="char-card">
              {crop ? (
                <div
                  class="char-portrait"
                  data-size={crop.size}
                  data-pos-x={crop.posX}
                  data-pos-y={crop.posY}
                  style={`background-image: url(${import.meta.env.BASE_URL}images/champions/600px-${char.slug}.png);`}
                />
              ) : (
                <div class="char-portrait char-portrait-fallback">
                  <span>{char.nameJa[0]}</span>
                </div>
              )}
              <span class="char-label">{char.nameJa}</span>
            </a>
          );
        })}
      </div>

      <!-- 広告スロット: キャラグリッド下 (Phase 2〜 AdSense に差し替え) -->
      <div class="ad-inline-placeholder" aria-hidden="true">
        <span class="ad-inline-label">広告</span>
        <span class="ad-inline-size">336 × 280</span>
        <span class="ad-inline-note">Phase 2〜</span>
      </div>
    </div>
  </section>
</Base>

<script>
  const WIKI_REF = 180; // キャラ画像の参照元（2XKO Wiki）の基準サイズ (px)
  function scalePortraits() {
    document.querySelectorAll<HTMLElement>('.char-portrait[data-size]').forEach(el => {
      const cardWidth = el.clientWidth;
      const scale = cardWidth / WIKI_REF;
      const size = Number(el.dataset.size) * scale;
      const posX = Number(el.dataset.posX) * scale;
      const posY = Number(el.dataset.posY) * scale;
      el.style.backgroundSize = `${size}px`;
      el.style.backgroundPosition = `${posX}px ${posY}px`;
    });
  }
  scalePortraits();
  window.addEventListener('resize', scalePortraits);
</script>

<style>
  .hero {
    text-align: center;
    padding: 1.5rem 0 1rem;
  }

  .hero-sub {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .nav-links {
    padding: 0 0 1.5rem;
  }

  .nav-links-row {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .nav-link-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.45rem 0.75rem;
    color: var(--color-text);
    font-size: 0.85rem;
    transition: border-color 0.15s;
    flex: 1;
    min-width: 0;
  }

  .nav-link-card:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .nav-link-label {
    font-weight: 700;
    font-size: 0.85rem;
  }

  .nav-link-desc {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .nav-link-disabled {
    pointer-events: none;
    opacity: 0.6;
  }

  .nav-link-disabled .nav-link-label {
    text-decoration: line-through;
  }

  .characters {
    padding: 0 0 1rem;
  }

  .char-grid-title {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    margin-bottom: 0.75rem;
  }

  .char-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .char-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
    }
  }

  @media (min-width: 960px) {
    .char-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .char-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .char-card:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .char-portrait {
    width: 100%;
    aspect-ratio: 6 / 5;
    background-repeat: no-repeat;
    background-color: var(--color-border);
  }

  .char-portrait-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .char-label {
    display: block;
    text-align: center;
    padding: 0.4rem 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* グリッド下インライン広告プレースホルダー */
  .ad-inline-placeholder {
    margin-top: 1.25rem;
    margin-left: auto;
    margin-right: auto;
    width: 336px;
    height: 280px;
    max-width: 100%;
    border: 1px dashed var(--color-border);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    background: var(--color-surface);
    opacity: 0.45;
    pointer-events: none;
  }

  /* PC 幅ではサイドバー広告が出るためインライン広告は非表示 */
  @media (min-width: 1360px) {
    .ad-inline-placeholder {
      display: none;
    }
  }

  .ad-inline-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .ad-inline-size {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    font-family: monospace;
  }

  .ad-inline-note {
    font-size: 0.55rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }
</style>
