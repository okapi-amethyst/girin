---
import Base from "../../layouts/Base.astro";
import { characters } from "../../data/characters";
import type { Character } from "../../data/characters";

export function getStaticPaths() {
  return characters.map((char) => ({
    params: { slug: char.slug },
    props: { char },
  }));
}

interface Props {
  char: Character;
}

const { char } = Astro.props;
const base = import.meta.env.BASE_URL;
const partners = characters.filter((c) => c.slug !== char.slug);

function scaleCrop(crop: { bgSize: string; bgPosition: string }) {
  const size = parseInt(crop.bgSize);
  const parts = crop.bgPosition.match(/-?\d+/g)?.map(Number) || [0, 0];
  return { size, posX: parts[0], posY: parts[1] };
}

function pairUrl(a: Character, b: Character): string {
  const charA = characters.indexOf(a);
  const charB = characters.indexOf(b);
  if (charA < charB) {
    return `${base}${a.slug}/${b.slug}/`;
  }
  return `${base}${b.slug}/${a.slug}/`;
}
---

<Base
  title={`${char.nameJa} コンボ | 2XKO GIRIN`}
  description={`${char.nameJa}のコンボ一覧。相方を選んで自分に合ったルートを探そう。`}
>
  <div class="container page">
    <nav class="breadcrumb">
      <a href={base}>トップ</a>
      <span>/</span>
      <span>{char.nameJa}</span>
    </nav>

    <header class="char-header">
      {char.crop ? (
        <div
          class="char-icon-portrait"
          data-size={scaleCrop(char.crop).size}
          data-pos-x={scaleCrop(char.crop).posX}
          data-pos-y={scaleCrop(char.crop).posY}
          style={`background-image: url(${base}images/champions/600px-${char.slug}.png);`}
        />
      ) : (
        <div class="char-icon-fallback">
          <span>{char.nameJa[0]}</span>
        </div>
      )}
      <div>
        <h1>{char.name}</h1>
        <p class="char-name-ja">{char.nameJa}</p>
      </div>
    </header>

    <section class="partner-section">
      <div class="section-header">
        <h2 class="section-title">パートナーチャンピオンを選択</h2>
        <a href={`${base}${char.slug}/juggernaut/`} class="juggernaut-link">
          <img
            src={`${base}images/fuses/Juggernaut_fuse_360.png`}
            alt="JUGGERNAUT"
            class="juggernaut-fuse-icon"
            width="28"
            height="28"
          />
          <span class="juggernaut-link-text">
            <span class="juggernaut-link-name">{char.nameJa} JUGGERNAUT</span>
            <span class="juggernaut-link-desc">ソロFuseコンボ</span>
          </span>
        </a>
      </div>
      <div class="partner-grid">
        {partners.map((p) => {
          const crop = p.crop ? scaleCrop(p.crop) : null;
          return (
            <a href={pairUrl(char, p)} class="partner-card">
              {crop ? (
                <div
                  class="partner-portrait"
                  data-size={crop.size}
                  data-pos-x={crop.posX}
                  data-pos-y={crop.posY}
                  style={`background-image: url(${base}images/champions/600px-${p.slug}.png);`}
                />
              ) : (
                <div class="partner-portrait partner-portrait-fallback">
                  <span>{p.nameJa[0]}</span>
                </div>
              )}
              <span class="partner-label">{p.nameJa}</span>
            </a>
          );
        })}
      </div>
    </section>

    <div class="back-to-top">
      <a href={base}>← トップに戻る</a>
    </div>

    <!-- 広告スロット: ページ末尾 (Phase 2〜 AdSense に差し替え) -->
    <div class="ad-inline-placeholder" aria-hidden="true">
      <span class="ad-inline-label">広告</span>
      <span class="ad-inline-size">336 × 280</span>
      <span class="ad-inline-note">Phase 2〜</span>
    </div>
  </div>
</Base>

<script>
  const WIKI_REF = 180; // キャラ画像の参照元（2XKO Wiki）の基準サイズ (px)
  function scalePortraits() {
    document.querySelectorAll<HTMLElement>('[data-size]').forEach(el => {
      const w = el.clientWidth;
      if (w === 0) return;
      const scale = w / WIKI_REF;
      el.style.backgroundSize = `${Number(el.dataset.size) * scale}px`;
      el.style.backgroundPosition = `${Number(el.dataset.posX) * scale}px ${Number(el.dataset.posY) * scale}px`;
    });
  }
  scalePortraits();
  window.addEventListener('resize', scalePortraits);
</script>

<style>
  .page {
    padding-top: 1.5rem;
    padding-bottom: 2rem;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.5rem;
  }

  .char-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .char-icon-portrait {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-repeat: no-repeat;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  .char-icon-fallback {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .char-header h1 {
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .char-name-ja {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .juggernaut-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.85rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text-muted);
    transition: border-color 0.15s, color 0.15s;
  }

  .juggernaut-link:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .juggernaut-fuse-icon {
    width: 28px;
    height: 28px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .juggernaut-link-text {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .juggernaut-link-name {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .juggernaut-link-desc {
    font-size: 0.65rem;
    color: var(--color-text-muted);
  }

  .partner-section {
    margin-bottom: 1rem;
  }

  .partner-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .partner-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
    }
  }

  @media (min-width: 960px) {
    .partner-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .partner-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .partner-card:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .partner-portrait {
    width: 100%;
    aspect-ratio: 6 / 5;
    background-repeat: no-repeat;
    background-color: var(--color-border);
  }

  .partner-portrait-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .partner-label {
    display: block;
    text-align: center;
    padding: 0.4rem 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .back-to-top {
    margin-top: 2rem;
    font-size: 0.85rem;
  }

  .back-to-top a {
    color: var(--color-text-muted);
  }

  .back-to-top a:hover {
    color: var(--color-text);
  }

  .ad-inline-placeholder {
    margin-top: 1.25rem;
    margin-left: auto;
    margin-right: auto;
    width: 336px;
    height: 280px;
    max-width: 100%;
    border: 1px dashed var(--color-border);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    background: var(--color-surface);
    opacity: 0.45;
    pointer-events: none;
  }

  @media (min-width: 1360px) {
    .ad-inline-placeholder {
      display: none;
    }
  }

  .ad-inline-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .ad-inline-size {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    font-family: monospace;
  }

  .ad-inline-note {
    font-size: 0.55rem;
    color: var(--color-text-muted);
    opacity: 0.7;
  }
</style>
